---
// CorporatePartners.astro - Chancelas B2B para redução de ceticismo e ganho de confiança
---

<section class="w-full bg-gray-900 border-y border-gray-800 py-6 px-4" aria-labelledby="partners-heading">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-center gap-6 md:gap-12 opacity-80 hover:opacity-100 transition-opacity duration-300">
    <h2 id="partners-heading" class="text-sm font-sans font-medium text-gray-400 uppercase tracking-widest text-center">
      Parceiros Corporativos Autorizados
    </h2>
    
    <div class="flex items-center justify-center gap-8 md:gap-16">
      <!-- Wellhub Logo/Vector -->
      <div class="flex items-center gap-1.5 grayscale hover:grayscale-0 transition-all duration-300">
        <svg viewBox="0 0 50 50" class="w-8 h-8 text-red-500 fill-current pr-1">
          <path d="M5,15 L15,35 L25,15 L35,35 L45,15" stroke="currentColor" stroke-width="7" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
        <span class="font-heading font-extrabold text-2xl text-white tracking-tight">Wellhub</span>
      </div>
      
      <!-- TotalPass Logo/Vector -->
      <div class="flex items-center gap-2 grayscale hover:grayscale-0 transition-all duration-300">
        <div class="relative w-8 h-8 flex items-center justify-center">
            <svg viewBox="0 0 100 100" class="absolute w-full h-full drop-shadow-md">
                <circle cx="35" cy="50" r="28" fill="#EC1C24" />
                <circle cx="65" cy="50" r="28" fill="#0055A5" style="mix-blend-mode: multiply;" />
            </svg>
        </div>
        <span class="font-heading font-black text-2xl text-white tracking-tighter transform scale-y-90">TOTALPASS</span>
      </div>
    </div>
  </div>
</section>
