---
// ModalitiesCatalog.astro - Catálogo Sanfonado Zero-JS para modalidades e conversão no WhatsApp
import { fetchSchedules, getShiftsFor } from '../utils/fetchSchedules';

const schedulesDb = await fetchSchedules();
const categories = [
  {
    title: "Aquáticos do Zero ao Avançado",
    image: "https://images.unsplash.com/photo-1519315901367-f34f9274ceb0?auto=format&fit=crop&q=80&w=800",
    classes: [
      { name: "Natação Bebês (A partir de 6 meses)", desc: "Estímulo aquático seguro ao desenvolvimento motor na primeira infância (pais na água)." },
      { name: "Natação Kids e Teens", desc: "Aprendizado lúdico e formativo cobrindo sobrevivência e todos os nados esportivos." },
      { name: "Natação Adulto", desc: "Foco livre! Desde quem tem trauma e deseja sobrevivência básica até ex-atletas polindo técnica cardiovascular." },
      { name: "Hidroginástica", desc: "Treino aeróbico extramamente vibrante e seguro para articulações. Queridinho da melhor idade." }
    ]
  },
  {
    title: "Lutas e Artes Marciais",
    image: "https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?auto=format&fit=crop&q=80&w=800",
    classes: [
      { name: "Muay Thai", desc: "Altíssimo gasto calórico e condicionamento. Chutes, socos e defesa pessoal na veia!" }
    ]
  },
  {
    title: "Danças e Expressão",
    image: "https://images.unsplash.com/photo-1508700115892-45ecd05ae2ad?auto=format&fit=crop&q=80&w=800",
    classes: [
      { name: "Ballet (Baby Class)", desc: "Primeiros movimentos de dança clássica com postura, disciplina e graça infantil." },
      { name: "Jazz e Hip Hop", desc: "Liberte energia pura com coreografias modernas, ritmos urbanos e condicionamento musical." },
      { name: "Sapateado (Baby Tap)", desc: "Muita coordenação motora com ritmo acústico direto dos próprios sapatos!" }
    ]
  },
  {
    title: "Mente e Corpo Saudável",
    image: "https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&q=80&w=800",
    classes: [
      { name: "Pilates Solo", desc: "Fortalecimento do Core, alívio de dores nas costas e correção biomecânica usando apenas o corpo." },
      { name: "Treino Funcional", desc: "Ganhe agilidade diária misturando saltos, giros e exercícios que imitam ações do dia-a-dia." }
    ]
  }
];

const whatsAppNumber = "5585999699439";
---

<section class="w-full bg-navy-deep py-20 px-4" aria-labelledby="catalog-heading">
  <div class="max-w-6xl mx-auto flex flex-col gap-10">
    <div class="text-center">
      <h2 id="catalog-heading" class="text-3xl md:text-5xl font-heading font-extrabold text-white">
        Grade de <span class="text-sun-yellow">Modalidades</span>
      </h2>
      <p class="mt-4 text-gray-300 font-sans text-lg max-w-2xl mx-auto">
        Descubra muito além dos pesos. Toque em uma categoria abaixo e agende uma aula experimental gratuita na sua modalidade favorita.
      </p>
    </div>

    <!-- Interface nativa em grupo sanfonado via 'details' HTML5 convertida para Cards Verticais -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
      {categories.map((category) => (
        <details class="group bg-gray-900 rounded-3xl overflow-hidden shadow-2xl transition-all duration-300 open:ring-2 open:ring-sun-yellow/50">
          <summary class="relative h-48 md:h-64 flex flex-col justify-end p-6 cursor-pointer outline-none overflow-hidden select-none">
            <!-- Imagem de Fundo Premium -->
            <img src={category.image} alt={category.title} class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:opacity-70 group-hover:scale-105 transition-all duration-700 ease-in-out" />
            <!-- Gradiente de Fade -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#0f172a] via-[#0f172a]/70 to-transparent"></div>
            
            <div class="relative z-10 flex items-end justify-between w-full">
              <h3 class="font-heading font-extrabold text-2xl md:text-3xl text-white tracking-wide shadow-black drop-shadow-md">{category.title}</h3>
              <div class="bg-sun-yellow text-navy-deep rounded-full p-2 group-open:rotate-180 transform transition-transform duration-300 ease-in-out shadow-lg">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-6 h-6 stroke-[3]"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
              </div>
            </div>
          </summary>

          <div class="flex flex-col gap-0 border-t border-gray-800 bg-[#162032]">
            {category.classes.map((cls) => (
              <div class="p-6 md:p-8 flex flex-col 2xl:flex-row 2xl:items-center justify-between gap-6 border-b border-gray-800/40 last:border-0 hover:bg-white/5 transition-colors">
                <div class="flex flex-col gap-1 max-w-xl">
                  <h4 class="font-heading font-bold text-xl text-sun-yellow">{cls.name}</h4>
                  <p class="font-sans text-gray-300 text-sm md:text-base leading-relaxed mt-1">
                    {cls.desc}
                  </p>
                  {getShiftsFor(cls.name, schedulesDb).length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-3 cursor-default">
                      {getShiftsFor(cls.name, schedulesDb).map(shift => (
                        <span class="inline-block bg-gray-800 text-gray-300 border border-gray-700 text-xs px-2.5 py-1 rounded-md shadow-sm font-sans tracking-wide">
                          {shift}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <div class="flex-shrink-0">
                  <a 
                    href={`https://wa.me/${whatsAppNumber}?text=Oi! Gostaria de saber os valores e agendar uma aula experimental de ${cls.name}`}
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center font-heading font-bold bg-[#25D366] hover:bg-[#128C7E] text-white py-2.5 px-6 rounded-full transition-colors w-full md:w-auto text-sm gap-2 whitespace-nowrap shadow-xl"
                  >
                    <svg class="w-5 h-5 mr-1" viewBox="0 0 448 512" fill="currentColor"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg>
                    Consultar Valores
                  </a>
                </div>
              </div>
            ))}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
