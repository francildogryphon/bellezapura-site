---
import Layout from '../layouts/Layout.astro';
import HeroHeader from '../components/HeroHeader.astro';
import CorporatePartners from '../components/CorporatePartners.astro';
import ShowcaseGallery from '../components/ShowcaseGallery.astro';
import ModalitiesCatalog from '../components/ModalitiesCatalog.astro';
import QuizEngine from '../components/QuizEngine.astro';
import FaqSection from '../components/FaqSection.astro';
import LocationMap from '../components/LocationMap.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Belleza Pura">
	<main class="flex min-h-screen flex-col items-center justify-start min-w-full">
		<HeroHeader />
		<CorporatePartners />
		<ShowcaseGallery />
		<QuizEngine />
		<ModalitiesCatalog />
		<FaqSection />
		<LocationMap />
	</main>
	<Footer />
</Layout>
